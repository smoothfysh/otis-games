<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>Color Splash — Otis Games</title>
  <link rel="stylesheet" href="../styles/main.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><circle cx='16' cy='16' r='14' fill='%23FFB5C2'/></svg>">
  <style>
    .color-splash { width: 100%; height: 100dvh; display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--bg); position: relative; overflow: hidden; padding-top: var(--header-h); }

    /* The character */
    .cs-character {
      width: 160px; height: 180px; margin-bottom: 24px;
      position: relative; animation: float 2.5s ease-in-out infinite;
      transition: var(--transition);
      flex-shrink: 0;
    }
    .cs-character.happy { animation: bounce 0.5s ease; }

    .cs-prompt {
      font-size: clamp(1.3rem, 4vw, 2rem); font-weight: 700;
      margin-bottom: 24px; text-align: center;
      min-height: 2.5rem; animation: fadeIn 0.4s ease;
    }

    .cs-colors {
      display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;
      padding: 0 16px;
      max-width: 100%;
    }
    .cs-color-btn {
      width: 100px; height: 100px; border-radius: 50%;
      border: 5px solid rgba(255,255,255,0.7); cursor: pointer;
      transition: var(--transition); touch-action: manipulation;
      box-shadow: 0 6px 16px var(--shadow);
      flex-shrink: 0;
    }
    .cs-color-btn:active { transform: scale(0.9); }
    .cs-color-btn.wrong { animation: wobble 0.4s ease; }

    .cs-progress {
      position: absolute; bottom: 20px; left: 0; right: 0;
      text-align: center; font-size: 0.85rem; opacity: 0.5;
    }

    @media (max-width: 768px) {
      .cs-character { width: 140px; height: 158px; margin-bottom: 16px; }
      .cs-colors { gap: 12px; }
      .cs-color-btn { width: 90px; height: 90px; }
    }

    @media (max-width: 480px) {
      .cs-character { width: 120px; height: 135px; }
      .cs-color-btn { width: 80px; height: 80px; }
      .cs-prompt { font-size: clamp(1.2rem, 5vw, 1.8rem); }
    }
  </style>
</head>
<body>
  <div class="color-splash">
    <div class="game-header">
      <a href="../index.html" class="back-link">←</a>
      <span style="font-weight:700;font-size:0.9rem;color:var(--violet)">Color Splash</span>
      <a href="../index.html" class="brand-link">Otis Games</a>
    </div>

    <!-- Character SVG rendered by JS -->
    <div class="cs-character" id="csCharacter"></div>
    <div class="cs-prompt" id="csPrompt">Find the color!</div>
    <div class="cs-colors" id="csColors"></div>
    <div class="cs-progress" id="csProgress">1 / 6</div>
  </div>

  <script src="../scripts/shared.js"></script>
  <script>
    (function() {
      const COLORS = [
        { name: 'Coral', hex: '#FF6B6B' },
        { name: 'Teal', hex: '#4ECDC4' },
        { name: 'Sky Blue', hex: '#45B7D1' },
        { name: 'Mint', hex: '#96CEB4' },
        { name: 'Sunset Orange', hex: '#FFB74D' },
        { name: 'Violet', hex: '#C9B1FF' }
      ];

      let currentRound = 0;
      let currentColor = null;
      let canTap = true;

      const charEl = document.getElementById('csCharacter');
      const promptEl = document.getElementById('csPrompt');
      const colorsEl = document.getElementById('csColors');
      const progressEl = document.getElementById('csProgress');

      function buildCharacter(color) {
        // Monument Valley-inspired triangular character
        return `<svg viewBox="0 0 100 120" width="100%" height="100%">
          <!-- Body (triangle) -->
          <polygon points="50,5 95,110 5,110" fill="${color.hex}" stroke="${color.hex}" stroke-width="2"/>
          <!-- Head (circle on top) -->
          <circle cx="50" cy="25" r="18" fill="${color.hex}" stroke="white" stroke-width="3"/>
          <!-- Eyes -->
          <circle cx="42" cy="22" r="3" fill="white"/>
          <circle cx="58" cy="22" r="3" fill="white"/>
          <circle cx="42" cy="22" r="1.5" fill="#2D3436"/>
          <circle cx="58" cy="22" r="1.5" fill="#2D3436"/>
          <!-- Smile -->
          <path d="M40 32 Q50 40 60 32" stroke="white" stroke-width="2" fill="none" stroke-linecap="round"/>
        </svg>`;
      }

      function loadRound() {
        if (currentRound >= COLORS.length) {
          createCelebration(document.body, 'You know all the colors!', '🎨', () => {
            currentRound = 0; loadRound();
          });
          progressEl.textContent = 'Amazing! 🌈';
          return;
        }

        currentColor = COLORS[currentRound];
        canTap = true;
        charEl.innerHTML = buildCharacter(currentColor);
        charEl.classList.remove('happy');
        promptEl.textContent = `Find the ${currentColor.name}!`;
        progressEl.textContent = `${currentRound + 1} / ${COLORS.length}`;

        // Build color buttons — 3 options (1 correct + 2 random others)
        const others = shuffleArray(COLORS.filter(c => c.name !== currentColor.name));
        const options = shuffleArray([currentColor, others[0], others[1]]);

        colorsEl.innerHTML = '';
        options.forEach(opt => {
          const btn = document.createElement('button');
          btn.className = 'cs-color-btn';
          btn.style.background = opt.hex;
          btn.dataset.name = opt.name;
          btn.addEventListener('click', () => handleTap(btn, opt));
          colorsEl.appendChild(btn);
        });

        OtisSpeech.speak(`Find the ${currentColor.name}`);
      }

      function handleTap(btn, opt) {
        if (!canTap) return;
        if (opt.name === currentColor.name) {
          // Correct!
          canTap = false;
          OtisAudio.playChime();
          charEl.classList.add('happy');
          const rect = btn.getBoundingClientRect();
          OtisParticles.burst(rect.left + rect.width / 2, rect.top + rect.height / 2, currentColor.hex, 20);
          currentRound++;
          setTimeout(loadRound, 1000);
        } else {
          // Wrong
          btn.classList.add('wrong');
          OtisAudio.playWobble();
          setTimeout(() => btn.classList.remove('wrong'), 400);
        }
      }

      loadRound();
    })();
  </script>
</body>
</html>